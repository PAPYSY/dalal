## Dalal - Environment variables

## Server
PORT=3000
NODE_ENV=development

## Auth / session (REQUIRED)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

## OAuth (REQUIRED)
VITE_APP_ID=your-app-id
OAUTH_SERVER_URL=https://your-oauth-server.example.com

## Database (recommended for community features)
DATABASE_URL=mysql://user:password@host:3306/dalal
## Cloud DB SSL (often required)
## DATABASE_SSL can be: "true" | "1" | "required"
DATABASE_SSL=true
## Set to "false" only if your provider tells you to
DATABASE_SSL_REJECT_UNAUTHORIZED=true
## Optional CA certificate content (PEM). If you paste it, keep \n escapes.
## Example: -----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
DATABASE_SSL_CA=
## Optional pool size (default 10)
DATABASE_POOL_LIMIT=10

## Optional: lock down allowed browser origins for state-changing requests
## Comma-separated list.
APP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

## Optional: admin bootstrap
OWNER_OPEN_ID=

## Optional: Manus forge proxy (maps/storage/llm)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

